# QuantumCipherSim — Environment Configuration
# Copy this file to .env and fill in your values.
# The app will use SQLite automatically if DATABASE_URL is not set.

# ── Database ──────────────────────────────────────────────────────────────
# PostgreSQL (production):
# DATABASE_URL=postgresql://username:password@localhost:5432/quantumciphersim

# SQLite (local dev, no setup needed — this is the default):
# DATABASE_URL=sqlite:///./quantumciphersim.db

# ── App ───────────────────────────────────────────────────────────────────
APP_ENV=development
